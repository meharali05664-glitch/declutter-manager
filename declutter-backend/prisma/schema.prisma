generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  phone         String?        @unique
  email         String?        @unique
  password      String?
  name          String
  country       String         @default("PK")
  currency      String         @default("PKR")
  isPro         Boolean        @default(false)
  createdAt     DateTime       @default(now())
  subscriptions Subscription[]
  notifications Notification[]
}

model Subscription {
  id               String   @id @default(uuid())
  name             String
  category         String   @default("Other")
  icon             String   @default("📦")
  color            String   @default("#7C3AED")
  amount           Float
  myShare          Float
  billingCycle     String   @default("monthly")
  nextRenewal      DateTime
  status           String   @default("active")
  isShared         Boolean  @default(false)
  sharedWith       String   @default("[]")
  cancelDifficulty String   @default("yellow")
  paymentMethod    String?
  usageHours       Float    @default(0)
  isZombie         Boolean  @default(false)
  notes            String?
  isTrial          Boolean  @default(false)
  trialEndDate     DateTime?
  postTrialAmount  Float?
  userId           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  title          String
  message        String
  type           String   @default("renewal_reminder")
  subscriptionId String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
